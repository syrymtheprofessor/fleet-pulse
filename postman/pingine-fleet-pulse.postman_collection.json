{
  "info": {
    "name": "Pingine Fleet Pulse",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "Get vehicle by id",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/vehicles/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa"
      }
    },
    {
      "name": "Get last trip",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/v1/vehicles/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/last-trip"
      }
    },
    {
      "name": "Refresh vehicle metadata",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/v1/vehicles/aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa/refresh"
      }
    }
  ]
}
